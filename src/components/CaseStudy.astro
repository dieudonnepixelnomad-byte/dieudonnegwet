---
/**
 * Corps d'une étude de cas : hero (tags + titre), cartes méthode
 * (Comprendre → Monétiser), statut sur carte sombre, CTA gradient.
 */
import Button from './Button.astro';
import { whatsappUrl } from '../consts';

interface Section {
  icon: string;
  titre: string;
  contenu?: string;
  liste?: string[];
}

interface Props {
  /** Titre affiché — la partie accentuée en bleu */
  nomDebut: string;
  nomAccent: string;
  /** Second tag à côté de "Projet client" (ex: "Douala · Marketplace") */
  tagInfo: string;
  /** Tag vert si l'app est en ligne */
  tagInfoOnline?: boolean;
  contexte: string;
  sections: Section[];
  statut: string;
  statutOnline?: boolean;
  ctaTitre: string;
  ctaAccent: string;
}

const {
  nomDebut,
  nomAccent,
  tagInfo,
  tagInfoOnline = false,
  contexte,
  sections,
  statut,
  statutOnline = false,
  ctaTitre,
  ctaAccent,
} = Astro.props;

const wa = whatsappUrl("Bonjour Dieudonné, j'ai un projet d'app et j'aimerais en discuter.");
---

<header class="case-head">
  <div class="container narrow">
    <a href="/etudes-de-cas" class="back">← Études de cas</a>
    <div class="tags">
      <span class="tag blue">Projet client</span>
      <span class:list={['tag', tagInfoOnline ? 'green' : 'grey']}>{tagInfo}</span>
    </div>
    <h1>{nomDebut}<span class="accent">{nomAccent}</span></h1>
    <p class="muted lead">{contexte}</p>
  </div>
</header>

<section class="case-body">
  <div class="container steps">
    {
      sections.map((s) => (
        <div class="card step" data-reveal>
          <span class="s-icon" aria-hidden="true">{s.icon}</span>
          <div>
            <h2>{s.titre}</h2>
            {s.contenu && <p>{s.contenu}</p>}
            {s.liste && (
              <ul>
                {s.liste.map((item) => (
                  <li>
                    <span class="bullet" aria-hidden="true">▸</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))
    }

    <div class="statut" data-reveal>
      <span class:list={['tag', statutOnline ? 'green-dark' : 'blue-dark']}>Statut actuel</span>
      <p>{statut}</p>
    </div>
  </div>
</section>

<section class="case-cta">
  <div class="container center" data-reveal>
    <h2>{ctaTitre} <span class="accent">{ctaAccent}</span> ?</h2>
    <Button href={wa} whatsapp>Valider mon idée gratuitement</Button>
  </div>
</section>

<style>
  .narrow {
    max-width: 860px;
  }

  .case-head {
    padding-block: clamp(2.5rem, 6vw, 5rem) clamp(1.875rem, 4vw, 3rem);
  }

  .back {
    font-size: 0.88rem;
    color: var(--muted);
  }

  .back:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 16px;
  }

  .blue {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .grey {
    background: #edf1f7;
    color: var(--muted);
  }

  .green {
    background: #e7f7ee;
    color: #1a9d5a;
  }

  .blue-dark {
    background: rgba(46, 142, 255, 0.18);
    color: #8fc0ff;
  }

  .green-dark {
    background: rgba(26, 157, 90, 0.2);
    color: #7be0a8;
  }

  .case-head h1 {
    font-size: clamp(1.875rem, 4.6vw, 3.25rem);
    margin: 1.25rem 0 0;
  }

  .lead {
    font-size: clamp(1rem, 1.6vw, 1.1875rem);
    max-width: 58ch;
    margin-top: 1.25rem;
  }

  .case-body {
    padding-block: clamp(1.25rem, 3vw, 2.5rem) clamp(3rem, 7vw, 5.5rem);
  }

  .steps {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.375rem;
    border-radius: 16px;
    padding: 1.625rem 1.75rem;
  }

  .s-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }

  .step h2 {
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }

  .step p {
    color: #3a4a63;
    font-size: 1rem;
    margin: 0.6rem 0 0;
  }

  .step ul {
    margin: 0.75rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .step li {
    display: flex;
    gap: 0.6rem;
    color: #3a4a63;
    font-size: 0.97rem;
  }

  .bullet {
    color: var(--accent);
    flex: none;
  }

  .statut {
    background: var(--ink);
    color: #fff;
    border-radius: 16px;
    padding: 1.75rem 1.875rem;
    margin-top: 0.5rem;
  }

  .statut p {
    color: #dce4f0;
    font-size: 1.0625rem;
    margin: 0.875rem 0 0;
  }

  .case-cta {
    padding-block: clamp(3rem, 7vw, 5.5rem);
    background: linear-gradient(180deg, var(--bg), var(--accent-soft));
  }

  .center {
    max-width: 640px;
    text-align: center;
  }

  .case-cta h2 {
    font-size: clamp(1.5rem, 3.4vw, 2.375rem);
    margin-bottom: 1.6rem;
  }
</style>
