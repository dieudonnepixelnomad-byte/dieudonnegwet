---
import { KOBARA_PLAY_URL } from '../consts';

interface Props {
  /** Libellé du bouton Google Play */
  playLabel?: string;
  /** Fond clair (section gradient) : badge App Store sur fond blanc */
  onLight?: boolean;
}
const { playLabel = 'Disponible sur Google Play', onLight = false } = Astro.props;
---

<div class="badges">
  <a href={KOBARA_PLAY_URL} class="storebtn play" target="_blank" rel="noopener noreferrer">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M4 2.7v18.6c0 .4.4.6.7.4l10.6-9.3c.2-.2.2-.6 0-.8L4.7 2.3c-.3-.2-.7 0-.7.4Zm13.5 6.9-2.6 2.2 2.6 2.3 3.4-1.6c.7-.4.7-1 0-1.3l-3.4-1.6Z" />
    </svg>
    {playLabel}
  </a>
  <span class:list={['storebtn', 'apple', { light: onLight }]} aria-label="Bientôt disponible sur l'App Store">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M16.4 12.9c0-2.4 2-3.6 2.1-3.7-1.1-1.7-2.9-1.9-3.5-1.9-1.5-.2-2.9.9-3.7.9-.8 0-1.9-.9-3.2-.8-1.6 0-3.1 1-4 2.4-1.7 2.9-.4 7.3 1.2 9.7.8 1.2 1.8 2.5 3 2.4 1.2 0 1.7-.8 3.2-.8s1.9.8 3.2.8c1.3 0 2.2-1.2 3-2.4.9-1.4 1.3-2.7 1.3-2.8-.1 0-2.6-1-2.6-3.8ZM14 5.7c.7-.8 1.1-1.9 1-3-1 0-2.1.7-2.8 1.5-.6.7-1.2 1.9-1 3 1 .1 2.1-.6 2.8-1.5Z" />
    </svg>
    Bientôt sur l'App Store
  </span>
</div>

<style>
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }

  .storebtn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.875rem 1.375rem;
    border-radius: 14px;
    font-weight: 600;
    font-size: 0.94rem;
    line-height: 1.2;
  }

  .play {
    background: var(--ink);
    color: #fff;
    text-decoration: none;
    box-shadow: 0 8px 22px rgba(16, 25, 43, 0.25);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .play:hover {
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(16, 25, 43, 0.3);
  }

  .apple {
    background: #edf1f7;
    color: #8695ae;
    border: 1px solid var(--border);
    cursor: default;
  }

  .apple.light {
    background: #fff;
  }
</style>
