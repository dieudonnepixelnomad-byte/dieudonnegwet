---
import AppLayout from '../../layouts/AppLayout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import StoreBadges from '../../components/StoreBadges.astro';
import { SITE_URL, KOBARA_PLAY_URL } from '../../consts';

const appSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'Kobara',
  operatingSystem: 'Android',
  applicationCategory: 'FinanceApplication',
  description:
    "Kobara organise ton argent dès qu'il arrive : budget par enveloppes et répartition en cascade, pensés pour les revenus irréguliers. 100% local, sans compte.",
  url: `${SITE_URL}/apps/kobara`,
  installUrl: KOBARA_PLAY_URL,
  author: {
    '@type': 'Person',
    name: 'Gwet Bikoun Dieudonné',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'XAF',
  },
});

const cascade = [
  { titre: "Vous recevez de l'argent", texte: 'Peu importe le montant, peu importe quand.' },
  {
    titre: 'Kobara le répartit en cascade',
    texte:
      "D'abord vos charges obligatoires, puis vos charges ajustables, selon vos priorités définies à l'avance.",
  },
  {
    titre: 'Vous voyez toujours où vous en êtes',
    texte: "Ce qui est déjà financé, ce qui ne l'est pas encore.",
  },
];

const features = [
  {
    icon: '📥',
    texte: "Budget par enveloppes adapté aux rentrées d'argent irrégulières",
  },
  {
    icon: '💧',
    texte: "Répartition automatique en cascade dès que l'argent arrive",
  },
  {
    icon: '📊',
    texte:
      "Statuts clairs : Déficitaire / Fragile / Soutenable, pour voir d'un coup d'œil votre situation réelle",
  },
  {
    icon: '🔒',
    texte: '100% local — aucune donnée envoyée sur un serveur, aucun compte à créer',
  },
];
---

<AppLayout
  title="Kobara — Budget par enveloppes pour revenus irréguliers"
  description="Kobara ne suit pas tes dépenses. Elle organise ton argent dès qu'il arrive, pour que tes charges essentielles soient toujours couvertes. 100% local, aucun compte."
  appName="Kobara"
>
  <script is:inline type="application/ld+json" set:html={appSchema} slot="head" />

  <!-- Hero -->
  <header class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div>
        <div class="brand">
          <span class="brand-logo">K</span>
          <span class="brand-name">Kobara</span>
        </div>
        <h1>
          Kobara ne suit pas tes dépenses. Elle <span class="accent">organise ton argent</span>
          dès qu'il arrive.
        </h1>
        <p class="muted lead">
          Pour que tes charges essentielles soient toujours couvertes — même avec un revenu qui
          varie.
        </p>
        <div class="badges-wrap">
          <StoreBadges />
        </div>
      </div>
      <div class="phone-wrap" data-reveal>
        <div class="phone">
          <div class="phone-screen">
            <div class="notch"><span></span></div>
            <div class="screen-body">
              <div class="screen-title">Revenu reçu · 85 000 F</div>
              <div class="env">
                <div class="env-row"><span>Loyer</span><span class="ok">Financé</span></div>
                <div class="bar ok-bg"><div class="fill ok-fill" style="width:100%"></div></div>
              </div>
              <div class="env">
                <div class="env-row"><span>Nourriture</span><span class="mid">Fragile</span></div>
                <div class="bar mid-bg"><div class="fill mid-fill" style="width:64%"></div></div>
              </div>
              <div class="env">
                <div class="env-row"><span>Transport</span><span class="low">Déficitaire</span></div>
                <div class="bar low-bg"><div class="fill low-fill" style="width:28%"></div></div>
              </div>
              <div class="screen-caption">capture d'écran Kobara</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Problème -->
  <section class="section probleme">
    <div class="container narrow center-text" data-reveal>
      <Eyebrow>Le problème</Eyebrow>
      <h2>Un revenu irrégulier, ce n'est pas un problème de <span class="accent">discipline</span></h2>
      <p class="muted">
        Un mois vous encaissez bien, le mois suivant presque rien. Les apps de budget classiques
        supposent un salaire fixe qui tombe le même jour chaque mois — elles ne collent pas à votre
        réalité de freelance, de commission, ou de revenu variable.
      </p>
    </div>
  </section>

  <!-- Méthode cascade -->
  <section class="section">
    <div class="container narrow-lg">
      <div class="section-head center" data-reveal>
        <Eyebrow>La solution — méthode cascade</Eyebrow>
        <h2>Chaque franc qui entre a déjà une <span class="accent">destination</span></h2>
      </div>
      <div class="cascade">
        {
          cascade.map((c, i) => (
            <article class="card etape" data-reveal>
              <div class="num">{i + 1}</div>
              <h3>{c.titre}</h3>
              <p class="muted">{c.texte}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Fonctionnalités -->
  <section class="section features-section">
    <div class="container narrow-lg">
      <div class="section-head" data-reveal>
        <Eyebrow>Fonctionnalités</Eyebrow>
      </div>
      <div class="features">
        {
          features.map((f) => (
            <div class="feature" data-reveal>
              <span class="f-icon" aria-hidden="true">{f.icon}</span>
              <p>{f.texte}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Confidentialité -->
  <section class="section">
    <div class="container narrow-md" data-reveal>
      <div class="privacy">
        <span class="p-icon" aria-hidden="true">🔒</span>
        <div>
          <span class="dark-eyebrow">Confidentialité</span>
          <h2>Vos données financières ne quittent jamais votre téléphone</h2>
          <p>
            Kobara fonctionne entièrement en local. Pas de compte, pas de serveur, pas de tracking.
            Vos chiffres restent à vous.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="final-cta">
    <div class="container center-text" data-reveal>
      <h2>Reprenez le contrôle, même avec un <span class="accent">revenu qui varie</span></h2>
      <div class="badges-center">
        <StoreBadges playLabel="Télécharger sur Google Play" onLight />
      </div>
    </div>
  </section>
</AppLayout>

<style>
  .narrow {
    max-width: 760px;
  }

  .narrow-md {
    max-width: 820px;
  }

  .narrow-lg {
    max-width: 1000px;
  }

  .center-text {
    text-align: center;
  }

  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3rem, 8vw, 6rem);
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(600px 400px at 78% 30%, var(--accent-soft), transparent 70%);
  }

  .hero-grid {
    position: relative;
    max-width: 1120px;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 3.75rem);
    align-items: center;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }

  .brand-logo {
    width: 52px;
    height: 52px;
    border-radius: 13px;
    background: linear-gradient(135deg, var(--accent), #1a6fe0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 700;
    color: #fff;
    box-shadow: 0 8px 20px rgba(46, 142, 255, 0.4);
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 600;
  }

  .hero h1 {
    font-size: clamp(1.625rem, 3.6vw, 2.5rem);
    margin: 1.6rem 0 0;
    max-width: 20ch;
  }

  .lead {
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    max-width: 48ch;
    margin-top: 1.25rem;
  }

  .badges-wrap {
    margin-top: 2rem;
  }

  /* Phone mockup */
  .phone-wrap {
    display: flex;
    justify-content: center;
  }

  .phone {
    width: 270px;
    height: 548px;
    background: var(--ink);
    border-radius: 38px;
    padding: 11px;
    box-shadow: 0 30px 60px rgba(16, 25, 43, 0.28);
  }

  html.js .phone {
    animation: floaty 6s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    html.js .phone {
      animation: none;
    }
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 29px;
    background: var(--bg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .notch {
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .notch span {
    width: 70px;
    height: 5px;
    border-radius: 3px;
    background: var(--ink);
  }

  .screen-body {
    padding: 8px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
    background: repeating-linear-gradient(135deg, #fff, #fff 11px, #f4f7fc 11px, #f4f7fc 22px);
  }

  .screen-title {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--muted);
  }

  .env {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 13px 15px;
  }

  .env-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .env-row .ok {
    color: #1a9d5a;
    font-weight: 600;
  }

  .env-row .mid {
    color: var(--accent);
    font-weight: 600;
  }

  .env-row .low {
    color: #d2822a;
    font-weight: 600;
  }

  .bar {
    height: 7px;
    border-radius: 4px;
    margin-top: 8px;
  }

  .ok-bg {
    background: #e7f7ee;
  }

  .mid-bg {
    background: var(--accent-soft);
  }

  .low-bg {
    background: #fbefe0;
  }

  .fill {
    height: 100%;
    border-radius: 4px;
  }

  .ok-fill {
    background: #1a9d5a;
  }

  .mid-fill {
    background: var(--accent);
  }

  .low-fill {
    background: #d2822a;
  }

  .screen-caption {
    margin-top: auto;
    text-align: center;
    font-family: ui-monospace, Menlo, monospace;
    font-size: 0.625rem;
    color: #a9b6cd;
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Problème */
  .probleme {
    background: #fff;
    border-block: 1px solid var(--border);
  }

  .probleme h2 {
    margin: 1.1rem 0 1.25rem;
  }

  .probleme p {
    font-size: 1.0625rem;
    margin: 0;
  }

  /* Cascade */
  .cascade {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .etape {
    border-radius: 16px;
    padding: 1.75rem;
  }

  .num {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
  }

  .etape h3 {
    font-size: 1.1875rem;
    margin: 1.1rem 0 0.6rem;
  }

  .etape p {
    font-size: 0.94rem;
    margin: 0;
  }

  @media (max-width: 860px) {
    .cascade {
      grid-template-columns: 1fr;
    }
  }

  /* Fonctionnalités */
  .features-section {
    background: #fff;
    border-block: 1px solid var(--border);
  }

  .features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .feature {
    display: flex;
    gap: 1rem;
    background: #f7faff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.375rem;
  }

  .f-icon {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: 11px;
    background: var(--accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }

  .feature p {
    color: var(--ink);
    font-size: 0.97rem;
    margin: 0;
    padding-top: 6px;
  }

  @media (max-width: 700px) {
    .features {
      grid-template-columns: 1fr;
    }
  }

  /* Confidentialité */
  .privacy {
    background: var(--ink);
    color: #fff;
    border-radius: 18px;
    padding: clamp(1.75rem, 4vw, 2.75rem);
    display: flex;
    gap: 1.375rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .p-icon {
    flex: none;
    width: 52px;
    height: 52px;
    border-radius: 13px;
    background: rgba(46, 142, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.625rem;
  }

  .privacy > div {
    flex: 1;
    min-width: 240px;
  }

  .dark-eyebrow {
    display: inline-block;
    background: rgba(46, 142, 255, 0.18);
    color: #8fc0ff;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 13px;
    border-radius: 20px;
  }

  .privacy h2 {
    font-size: clamp(1.3125rem, 2.6vw, 1.75rem);
    color: #fff;
    margin: 1rem 0 0.75rem;
  }

  .privacy p {
    color: #b7c3d6;
    margin: 0;
  }

  /* CTA final */
  .final-cta {
    padding-block: clamp(3.5rem, 8vw, 6.25rem);
    background: linear-gradient(180deg, var(--bg), var(--accent-soft));
  }

  .final-cta h2 {
    font-size: clamp(1.625rem, 3.6vw, 2.625rem);
    max-width: 720px;
    margin-inline: auto;
  }

  .badges-center {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }
</style>
