---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { whatsappUrl, WHATSAPP_NUMBER_DISPLAY, SOCIAL_LINKS } from '../consts';

const wa = whatsappUrl("Bonjour Dieudonné, j'aimerais échanger avec vous.");

const socials = [
  { nom: 'TikTok', mono: 'TT', url: SOCIAL_LINKS.tiktok },
  { nom: 'Instagram', mono: 'IG', url: SOCIAL_LINKS.instagram },
  { nom: 'YouTube', mono: 'YT', url: SOCIAL_LINKS.youtube },
  { nom: 'LinkedIn', mono: 'in', url: SOCIAL_LINKS.linkedin },
];
---

<BaseLayout
  title="Contact — Dieudonné Gwet"
  description="Le plus rapide, c'est WhatsApp. Discutons de votre idée d'app — premier échange gratuit et honnête."
>
  <section class="contact">
    <div class="container narrow">
      <div class="head" data-reveal>
        <Eyebrow>Contact</Eyebrow>
        <h1>On se parle <span class="accent">où</span> ?</h1>
        <p class="muted lead">
          Le plus rapide, c'est WhatsApp. Mais tu peux aussi me suivre là où je partage du contenu
          sur la création et la monétisation d'apps mobiles.
        </p>
      </div>

      <div class="wa-card" data-reveal>
        <div class="glow" aria-hidden="true"></div>
        <div class="wa-inner">
          <div class="wa-icon" aria-hidden="true">💬</div>
          <h2>Le premier échange est gratuit</h2>
          <p>
            On regarde ensemble si votre idée tient la route — et si ce n'est pas le cas, je vous
            le dirai aussi.
          </p>
          <Button href={wa} whatsapp class="cta-big">Discuter sur WhatsApp</Button>
          <p class="number">{WHATSAPP_NUMBER_DISPLAY}</p>
        </div>
      </div>

      <div class="socials-block" data-reveal>
        <p class="socials-title">Où je partage du contenu</p>
        <div class="socials">
          {
            socials.map((s) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer">
                <span class="mono" aria-hidden="true">{s.mono}</span>
                <span class="name">{s.nom}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .narrow {
    max-width: 720px;
  }

  .contact {
    padding-block: clamp(3rem, 8vw, 6.875rem);
  }

  .head {
    text-align: center;
  }

  .head h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    margin-top: 1.35rem;
  }

  .lead {
    font-size: clamp(1rem, 1.6vw, 1.1875rem);
    max-width: 48ch;
    margin: 1.25rem auto 0;
  }

  /* Carte WhatsApp */
  .wa-card {
    background: var(--ink);
    color: #fff;
    border-radius: 20px;
    padding: clamp(1.875rem, 4vw, 2.75rem);
    margin-top: 2.75rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(500px 300px at 80% 20%, rgba(46, 142, 255, 0.25), transparent 70%);
  }

  .wa-inner {
    position: relative;
  }

  .wa-icon {
    width: 60px;
    height: 60px;
    margin: 0 auto;
    border-radius: 16px;
    background: rgba(46, 142, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.875rem;
  }

  .wa-card h2 {
    font-size: clamp(1.25rem, 2.6vw, 1.625rem);
    color: #fff;
    margin: 1.25rem 0 0.5rem;
  }

  .wa-card p {
    color: #a9b6cd;
    font-size: 0.97rem;
    max-width: 38ch;
    margin: 0 auto 1.6rem;
  }

  .number {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 0.8125rem !important;
    color: var(--muted) !important;
    margin: 1rem auto 0 !important;
  }

  :global(.cta-big) {
    padding: 1rem 2rem !important;
    font-size: 1rem !important;
  }

  /* Réseaux */
  .socials-block {
    margin-top: 2.75rem;
  }

  .socials-title {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .socials {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.875rem;
  }

  .socials a {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1rem 1.125rem;
    color: var(--ink);
    text-decoration: none;
    box-shadow: 0 2px 10px rgba(16, 25, 43, 0.05);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .socials a:hover {
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: 0 12px 26px rgba(16, 25, 43, 0.1);
  }

  .mono {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: 11px;
    background: var(--accent-soft);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
  }

  .name {
    font-weight: 600;
    font-size: 0.94rem;
  }
</style>
