---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Constellation from '../components/Constellation.astro';
import { SITE_NAME, SITE_URL, WHATSAPP_URL, DEFAULT_DESCRIPTION } from '../consts';

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  description: DEFAULT_DESCRIPTION,
  inLanguage: 'fr',
});

const problemes = [
  {
    sans: 'Vous investissez dans le développement avant de savoir si ça va marcher',
    avec: "On valide l'idée et la cible avant la première ligne de code",
  },
  {
    sans: "Vous ne savez pas comment l'app pourrait un jour rapporter",
    avec: 'On réfléchit au modèle économique dès le départ',
  },
  {
    sans: 'Vous publiez une app, mais personne ne la télécharge',
    avec: 'On construit une stratégie pour vos 100 premiers utilisateurs',
  },
  {
    sans: "Vous avez peur de perdre du temps et de l'argent sur la mauvaise idée",
    avec: "Je vous dis honnêtement si ce n'est pas la bonne idée — même si ça veut dire ne pas travailler ensemble",
  },
  {
    sans: 'Vous ne savez pas par où commencer techniquement',
    avec: 'Je pilote toute la partie technique, vous restez sur votre expertise métier',
  },
];

const etapes = [
  {
    titre: 'Valider votre idée',
    texte:
      "Est-ce le bon problème, pour la bonne cible ? Comment cette app pourrait-elle un jour générer des revenus ? On répond à ces questions avant de construire quoi que ce soit.",
  },
  {
    titre: 'Construire le MVP',
    texte:
      "Une première version utile, centrée sur l'essentiel — pas une usine à gaz. Publiée dans les règles, sur les stores.",
  },
  {
    titre: 'Obtenir vos 100 premiers utilisateurs',
    texte:
      'Une app publiée sans utilisateurs ne prouve rien. Je vous accompagne pour trouver et convaincre vos 100 premiers vrais utilisateurs.',
  },
];

const faq = [
  {
    q: 'Pourquoi pas juste prendre un développeur sur Fiverr ou Upwork ?',
    a: "Un développeur exécute ce que vous lui demandez. Moi, je questionne d'abord si ce que vous demandez est la bonne chose à construire. La différence se voit après le lancement, pas avant.",
  },
  {
    q: 'Combien de temps pour valider une idée ?',
    a: "Ça dépend de la complexité de votre projet, mais l'objectif est toujours d'aller vite sans sauter les questions qui comptent : qui est la cible, quel est le problème réel, comment ça pourrait générer des revenus.",
  },
  {
    q: "Et si mon idée n'est pas la bonne ?",
    a: "Je vous le dis. Parfois une app n'est pas la solution — une automatisation WhatsApp ou une simple landing page peuvent suffire. Mon rôle est de vous aider à choisir le bon outil, pas de vous vendre le seul outil que je sais faire.",
  },
  {
    q: "Je n'ai pas de budget de développeur, on fait comment ?",
    a: "On en parle directement sur WhatsApp — c'est justement pour ça que le premier échange est gratuit, pour évaluer ensemble ce qui est réaliste selon votre situation.",
  },
];
---

<BaseLayout
  title="Dieudonné Gwet — Valider votre idée d'app avant de la construire"
  description={DEFAULT_DESCRIPTION}
>
  <script is:inline type="application/ld+json" set:html={websiteSchema} slot="head" />

  <!-- ============ HERO ============ -->
  <header class="hero">
    <Constellation />
    <div class="container hero-grid">
      <div class="hero-copy">
        <Eyebrow>Développeur produit · Flutter senior</Eyebrow>
        <h1>
          Avant de construire votre app, on va d'abord vérifier si c'est
          <span class="accent">la bonne idée</span>
        </h1>
        <p class="muted lead">
          Je suis Dieudonné, développeur Flutter senior depuis 10 ans. Je vous aide à valider votre
          idée, construire un MVP utile, et obtenir vos 100 premiers utilisateurs — pas juste à
          coder.
        </p>
        <div class="hero-actions">
          <Button href={WHATSAPP_URL} whatsapp>Valider mon idée gratuitement</Button>
          <a href="/qui-suis-je" class="link-underline">Découvrir ma méthode →</a>
        </div>
      </div>
      <div class="hero-cards" data-parallax>
        <div class="stat-card">
          <div class="stat">10 ans</div>
          <div class="stat-label">de développement mobile</div>
        </div>
        <div class="stat-card offset">
          <div class="stat">1 app</div>
          <div class="stat-label">en production — paiements réels testés</div>
        </div>
        <div class="stat-card">
          <div class="stat">1 app perso</div>
          <div class="stat-label">en cours de lancement</div>
        </div>
      </div>
    </div>
  </header>

  <!-- ============ LE PROBLÈME ============ -->
  <section class="section">
    <div class="container narrow-lg">
      <div class="section-head center" data-reveal>
        <Eyebrow>Le problème</Eyebrow>
        <h2>Coder sans valider, c'est parier <span class="accent">à l'aveugle</span></h2>
      </div>
      <div class="versus" data-reveal>
        <div class="v-head sans-head">Sans validation</div>
        <div class="v-head avec-head">Avec ma méthode</div>
        {
          problemes.map((row) => (
            <>
              <div class="v-cell sans">{row.sans}</div>
              <div class="v-cell avec">{row.avec}</div>
            </>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ LA MÉTHODE ============ -->
  <section class="section methode">
    <div class="container narrow-lg">
      <div class="section-head center" data-reveal>
        <Eyebrow>La méthode</Eyebrow>
        <h2>Trois étapes, dans <span class="accent">le bon ordre</span></h2>
      </div>
      <div class="steps">
        {
          etapes.map((s, i) => (
            <article class="step" data-reveal>
              <div class="step-num">{i + 1}</div>
              <h3>{s.titre}</h3>
              <p class="muted">{s.texte}</p>
            </article>
          ))
        }
      </div>
      <div class="center-cta" data-reveal>
        <Button href={WHATSAPP_URL} whatsapp>Valider mon idée gratuitement</Button>
      </div>
    </div>
  </section>

  <!-- ============ SEGMENTATION ============ -->
  <section class="section">
    <div class="container narrow-lg seg-grid">
      <div class="seg-main" data-reveal>
        <span class="dark-eyebrow">Pour vous</span>
        <h3>Vous avez une idée d'app, ou une activité qui pourrait en avoir besoin</h3>
        <p>Discutons de si c'est la bonne solution, et comment la valider.</p>
        <Button href={WHATSAPP_URL} whatsapp>Valider mon idée gratuitement</Button>
      </div>
      <div class="card seg-side" data-reveal>
        <h3>Je construis aussi mes propres apps</h3>
        <p class="muted">Découvrir Kobara et mes autres projets.</p>
        <a href="/apps" class="seg-link">Découvrir mes apps →</a>
      </div>
    </div>
  </section>

  <!-- ============ STORYTELLING ============ -->
  <section class="section story">
    <div class="container story-inner" data-reveal>
      <Eyebrow>Storytelling</Eyebrow>
      <h2>Je teste ma propre méthode <span class="accent">sur moi-même</span></h2>
      <div class="story-text">
        <p>
          Avant d'accompagner des clients, j'ai vécu le même problème qu'eux. Comme freelance, mes
          revenus sont irréguliers — un mois correct, un mois difficile, sans système pour
          m'organiser.
        </p>
        <p>
          Plutôt que de foncer sur une app, j'ai d'abord validé le vrai besoin. Puis j'ai construit
          <strong>Kobara</strong>, une app de budget par enveloppes pensée pour les revenus
          irréguliers. Je l'utilise moi-même, je l'améliore avec mes propres retours d'usage.
        </p>
        <p>
          C'est cette même méthode — comprendre avant de coder — que j'applique pour chaque client.
        </p>
      </div>
      <a href="/apps/kobara" class="seg-link">Découvrir Kobara →</a>
    </div>
  </section>

  <!-- ============ ÉTUDE DE CAS ============ -->
  <section class="section">
    <div class="container narrow-lg">
      <div data-reveal>
        <Eyebrow>Étude de cas</Eyebrow>
      </div>
      <a href="/etudes-de-cas/complete-learning" class="case-card" data-reveal>
        <div class="case-body">
          <span class="tag">Projet client</span>
          <h3>Complete Learning</h3>
          <p class="muted">
            Une marketplace de cours particuliers à Douala, connectant parents, élèves et
            enseignants, avec paiements Mobile Money testés en conditions réelles.
          </p>
          <span class="seg-link">Voir l'étude de cas complète →</span>
        </div>
        <div class="case-visual" aria-hidden="true"><span>CL</span></div>
      </a>
    </div>
  </section>

  <!-- ============ CE QUE JE NE SUIS PAS ============ -->
  <section class="not-me">
    <div class="container narrow" data-reveal>
      <span class="dark-eyebrow">Ce que je ne suis pas</span>
      <div class="not-list">
        <p>Je ne suis pas un développeur qui prend un cahier des charges, livre le fichier, et disparaît.</p>
        <p>Je ne suis pas quelqu'un qui vous pousse vers une application à tout prix.</p>
        <p>
          Je ne dis pas oui à toutes les idées —
          <span class="white">seulement à celles qui méritent d'être construites.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="section">
    <div class="container faq-wrap">
      <div class="section-head center" data-reveal>
        <Eyebrow>FAQ</Eyebrow>
        <h2>Les questions <span class="accent">honnêtes</span></h2>
      </div>
      {
        faq.map((item) => (
          <details class="faq-item" data-reveal>
            <summary>
              <span>{item.q}</span>
              <span class="faq-sign" aria-hidden="true" />
            </summary>
            <p class="muted">{item.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- ============ CTA FINAL ============ -->
  <section class="final-cta">
    <div class="container narrow" data-reveal>
      <h2>Un premier échange, <span class="accent">gratuit et honnête</span></h2>
      <p class="muted">
        On regarde ensemble si votre idée tient la route — et si ce n'est pas le cas, je vous le
        dirai aussi.
      </p>
      <Button href={WHATSAPP_URL} whatsapp class="cta-big">Valider mon idée gratuitement</Button>
    </div>
  </section>
</BaseLayout>

<script>
  // Parallaxe légère du hero (reveal + constellation gérés par composants partagés).
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const parallaxEl = document.querySelector('[data-parallax]') as HTMLElement | null;
    const canvas = document.querySelector('.constellation-canvas') as HTMLElement | null;
    window.addEventListener(
      'scroll',
      () => {
        const y = window.scrollY;
        if (parallaxEl) parallaxEl.style.transform = `translateY(${y * -0.06}px)`;
        if (canvas) canvas.style.transform = `translateY(${y * 0.12}px)`;
      },
      { passive: true }
    );
  }
</script>

<style>
  .narrow {
    max-width: 760px;
  }

  .narrow-lg {
    max-width: 1080px;
  }

  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 9vw, 7rem) clamp(3.75rem, 8vw, 6rem);
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .hero-copy h1 {
    margin-top: 1.35rem;
    max-width: 16ch;
    font-size: clamp(2.125rem, 5vw, 3.625rem);
  }

  .lead {
    font-size: clamp(1rem, 1.5vw, 1.1875rem);
    max-width: 52ch;
    margin-top: 1.35rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    margin-top: 2.1rem;
  }

  .link-underline {
    color: var(--muted);
    font-weight: 500;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
  }

  .link-underline:hover {
    color: var(--accent);
    text-decoration: none;
    border-color: var(--accent);
  }

  .hero-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stat-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem 1.4rem;
    box-shadow: 0 12px 30px rgba(16, 25, 43, 0.08);
  }

  html.js .stat-card {
    animation: floaty 6s ease-in-out infinite;
  }

  html.js .stat-card.offset {
    animation-delay: 0.8s;
  }

  html.js .stat-card:last-child {
    animation-delay: 1.6s;
  }

  .stat-card.offset {
    margin-left: 26px;
  }

  .stat {
    font-family: var(--font-display);
    font-size: 2.125rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.1;
  }

  .stat-label {
    color: var(--muted);
    font-size: 0.9rem;
    margin-top: 2px;
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .stat-card.offset {
      margin-left: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html.js .stat-card {
      animation: none;
    }
  }

  /* ---------- Tableau face-à-face ---------- */
  .versus {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .v-head {
    padding: 1.35rem 1.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .sans-head {
    background: #fff;
    color: var(--muted);
  }

  .avec-head {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .v-cell {
    padding: 1.25rem 1.5rem;
    font-size: 0.94rem;
  }

  .sans {
    background: #fff;
    color: var(--muted);
  }

  .avec {
    background: #f7faff;
    color: var(--ink);
  }

  @media (max-width: 700px) {
    .versus {
      grid-template-columns: 1fr;
    }
    .v-head {
      display: none;
    }
    .sans::before,
    .avec::before {
      display: block;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.3rem;
    }
    .sans::before {
      content: 'Sans validation';
      color: var(--muted);
    }
    .avec::before {
      content: 'Avec ma méthode';
      color: var(--accent);
    }
  }

  /* ---------- Méthode ---------- */
  .methode {
    background: #fff;
    border-block: 1px solid var(--border);
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

  .step {
    text-align: center;
  }

  .step-num {
    width: 64px;
    height: 64px;
    margin: 0 auto;
    border-radius: 50%;
    background: var(--accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--accent);
  }

  .step h3 {
    font-size: 1.25rem;
    margin: 1.25rem 0 0.6rem;
  }

  .step p {
    font-size: 0.94rem;
    max-width: 32ch;
    margin-inline: auto;
  }

  .center-cta {
    text-align: center;
    margin-top: 3.25rem;
  }

  @media (max-width: 860px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Segmentation ---------- */
  .seg-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 1.6rem;
    align-items: stretch;
  }

  .seg-main {
    background: var(--ink);
    color: #fff;
    border-radius: 18px;
    padding: clamp(1.75rem, 4vw, 2.75rem);
    position: relative;
    overflow: hidden;
  }

  .dark-eyebrow {
    display: inline-block;
    background: rgba(46, 142, 255, 0.18);
    color: #8fc0ff;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 13px;
    border-radius: 20px;
  }

  .seg-main h3 {
    font-size: clamp(1.375rem, 2.8vw, 1.875rem);
    color: #fff;
    margin: 1.1rem 0 0.75rem;
    max-width: 20ch;
  }

  .seg-main p {
    color: #a9b6cd;
    max-width: 40ch;
    margin-bottom: 1.6rem;
  }

  .seg-side {
    border-radius: 18px;
    padding: clamp(1.5rem, 3vw, 2.1rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .seg-side h3 {
    font-size: 1.25rem;
    margin-bottom: 0.6rem;
  }

  .seg-side p {
    font-size: 0.94rem;
    margin-bottom: 0;
  }

  .seg-link {
    color: var(--accent);
    font-weight: 600;
    margin-top: 1.1rem;
    display: inline-block;
  }

  @media (max-width: 860px) {
    .seg-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Storytelling ---------- */
  .story {
    background: #fff;
    border-block: 1px solid var(--border);
  }

  .story-inner {
    max-width: 820px;
  }

  .story-inner h2 {
    margin: 1.1rem 0 1.6rem;
    max-width: 22ch;
  }

  .story-text {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    color: #3a4a63;
    font-size: 1.0625rem;
  }

  .story-text strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* ---------- Étude de cas ---------- */
  .case-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    color: inherit;
    text-decoration: none;
    margin-top: 1.75rem;
    transition: box-shadow 0.18s ease, transform 0.18s ease;
  }

  .case-card:hover {
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .case-body {
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }

  .tag {
    display: inline-block;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 11px;
    border-radius: 14px;
  }

  .case-body h3 {
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    margin: 1rem 0 0.75rem;
  }

  .case-body p {
    font-size: 1rem;
    max-width: 44ch;
  }

  .case-visual {
    background: linear-gradient(135deg, var(--accent-soft), var(--bg));
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    border-left: 1px solid var(--border);
  }

  .case-visual span {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    color: #cfe1fb;
  }

  @media (max-width: 700px) {
    .case-card {
      grid-template-columns: 1fr;
    }
    .case-visual {
      min-height: 120px;
      border-left: none;
      border-top: 1px solid var(--border);
    }
  }

  /* ---------- Ce que je ne suis pas ---------- */
  .not-me {
    background: var(--ink);
    color: #fff;
    padding-block: clamp(3rem, 7vw, 5.5rem);
    text-align: center;
  }

  .not-me .container {
    max-width: 900px;
  }

  .not-list {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
    margin-top: 2.1rem;
    font-size: clamp(1.125rem, 2.2vw, 1.5rem);
    line-height: 1.4;
    color: #dce4f0;
  }

  .not-list p {
    margin: 0;
  }

  .white {
    color: #fff;
  }

  /* ---------- FAQ ---------- */
  .faq-wrap {
    max-width: 820px;
  }

  .faq-item {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(16, 25, 43, 0.05);
    margin-bottom: 0.75rem;
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--ink);
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-sign {
    flex: none;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.125rem;
  }

  .faq-sign::before {
    content: '+';
  }

  .faq-item[open] .faq-sign::before {
    content: '–';
  }

  .faq-item > p {
    padding: 0 1.5rem 1.35rem;
    margin: 0;
    font-size: 0.97rem;
  }

  /* ---------- CTA final ---------- */
  .final-cta {
    padding-block: clamp(3.5rem, 8vw, 6.25rem);
    background: linear-gradient(180deg, var(--bg), var(--accent-soft));
    text-align: center;
  }

  .final-cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.875rem);
  }

  .final-cta p {
