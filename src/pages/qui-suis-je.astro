---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Constellation from '../components/Constellation.astro';
import { SITE_URL, WHATSAPP_URL } from '../consts';

const personSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Gwet Bikoun Dieudonné',
  alternateName: 'Dieudonné Gwet',
  jobTitle: 'Développeur mobile Flutter senior',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Douala',
    addressCountry: 'CM',
  },
  url: `${SITE_URL}/qui-suis-je`,
  knowsAbout: [
    'Développement mobile Flutter',
    'Validation de produit',
    'MVP',
    'ASO',
    'Monétisation d’applications mobiles',
  ],
});

const dims = [
  {
    titre: 'Technique',
    texte:
      "Développement et reprise d'applications mobiles, architectures Flutter, optimisation de performance, publication sur les stores — avec les vraies contraintes du terrain africain : appareils d'entrée de gamme, connexions instables.",
  },
  {
    titre: 'Produit',
    texte:
      "J'ai compris avec le temps qu'une bonne app ne commence pas par le code. Elle commence par un problème clair, une cible précise, une première version réaliste.",
  },
  {
    titre: 'Marketing',
    texte:
      "Une app publiée mais invisible ne sert à rien. J'intègre ASO, stratégie de contenu et acquisition dans mon travail, pas seulement le développement.",
  },
];

const methode = [
  {
    titre: 'Comprendre',
    texte:
      "Qui est la cible, quel problème réel on résout, est-ce que ce problème est assez douloureux pour que quelqu'un paie.",
  },
  { titre: 'Valider', texte: "Confronter l'idée au terrain avant d'investir dans le développement." },
  { titre: 'Construire', texte: "Un MVP centré sur l'essentiel." },
  { titre: 'Publier', texte: "Dans les règles, sur Google Play et l'App Store." },
  {
    titre: 'Monétiser',
    texte: "Parce qu'une app qui ne génère rien n'est pas un actif, c'est une charge.",
  },
];

const contraste = [
  {
    oui: 'Un développeur Flutter senior avec une compréhension produit et marketing',
    non: 'Un développeur qui code sans jamais questionner la demande',
  },
  {
    oui: 'Un éditeur de mes propres applications',
    non: 'Un exécutant qui livre un fichier et disparaît',
  },
  {
    oui: "Un partenaire qui vous aide à passer d'une idée à une app publiée",
    non: 'Un prestataire qui dit oui à tout pour signer un contrat',
  },
  {
    oui: "Quelqu'un qui vous dit la vérité, même quand ce n'est pas ce que vous espérez entendre",
    non: 'Un coach qui vend du rêve sans parler budget, validation ou monétisation',
  },
];
---

<BaseLayout
  title="Qui suis-je — Gwet Bikoun Dieudonné, développeur produit Flutter"
  description="Développeur Flutter senior depuis 10 ans à Douala. Ni simple exécutant technique, ni formateur théorique. Je construis mes propres apps avant d'aider les autres."
>
  <script is:inline type="application/ld+json" set:html={personSchema} slot="head" />

  <!-- Hero -->
  <header class="hero">
    <Constellation points={40} />
    <div class="container hero-inner">
      <Eyebrow>Qui suis-je · Ma méthode</Eyebrow>
      <h1>
        Je construis mes propres apps avant d'aider les autres à
        <span class="accent">construire les leurs</span>
      </h1>
      <p class="muted lead">
        Je m'appelle Gwet Bikoun Dieudonné. Développeur mobile Flutter senior depuis plus de 10
        ans, basé à Douala. Je ne me positionne ni comme un simple exécutant technique, ni comme un
        formateur théorique qui n'a jamais publié son propre produit. Je suis entre les deux.
      </p>
    </div>
  </header>

  <!-- Parcours -->
  <section class="section">
    <div class="container narrow-lg">
      <div class="section-head" data-reveal>
        <Eyebrow>Mon parcours</Eyebrow>
        <h2>Trois dimensions qui <span class="accent">se répondent</span></h2>
      </div>
      <div class="dims">
        {
          dims.map((d) => (
            <article class="card dim" data-reveal>
              <h3>{d.titre}</h3>
              <p class="muted">{d.texte}</p>
            </article>
          ))
        }
      </div>
      <div class="conviction" data-reveal>
        Une conviction s'est construite avec ce parcours : l'Afrique n'a pas seulement besoin de
        développeurs qui codent des apps.
        <span class="white">
          Elle a besoin de gens capables d'expliquer pourquoi créer une app, quand la créer, et
          comment la monétiser.
        </span>
      </div>
    </div>
  </section>

  <!-- Méthode détaillée -->
  <section class="section methode-section">
    <div class="container narrow">
      <div class="section-head" data-reveal>
        <Eyebrow>Ma méthode — en détail</Eyebrow>
      </div>
      <ol class="methode-list">
        {
          methode.map((m, i) => (
            <li class="etape" data-reveal>
              <div class="num">{i + 1}</div>
              <div>
                <h3>{m.titre}</h3>
                <p class="muted">{m.texte}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Je suis / Je ne suis pas -->
  <section class="section">
    <div class="container narrow-lg">
      <div class="section-head center" data-reveal>
        <Eyebrow>Positionnement</Eyebrow>
        <h2>Ce que je suis <span class="accent">·</span> Ce que je ne suis pas</h2>
      </div>
      <div class="versus" data-reveal>
        <div class="v-head oui-head">Je suis</div>
        <div class="v-head non-head">Je ne suis pas</div>
        {
          contraste.map((row) => (
            <>
              <div class="v-cell oui">{row.oui}</div>
              <div class="v-cell non">{row.non}</div>
            </>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Vision -->
  <section class="vision">
    <div class="container narrow-md" data-reveal>
      <span class="dark-eyebrow">Ma vision</span>
      <h2>
        Devenir une <span class="light-accent">référence africaine</span> de la création et de la
        monétisation d'apps mobiles
      </h2>
      <div class="vision-text">
        <p>Je construis mes propres apps pour ne pas rester dans la théorie.</p>
        <p>Chaque app que je publie devient une preuve, une étude de cas, un support d'apprentissage.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="final-cta">
    <div class="container" data-reveal>
      <h2>On en <span class="accent">parle</span> ?</h2>
      <Button href={WHATSAPP_URL} whatsapp class="cta-big">Valider mon idée gratuitement</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .narrow {
    max-width: 900px;
  }

  .narrow-md {
    max-width: 820px;
  }

  .narrow-lg {
    max-width: 1080px;
  }

  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 9vw, 6.5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .hero-inner {
    position: relative;
    max-width: 860px;
  }

  .hero h1 {
    margin-top: 1.35rem;
    max-width: 20ch;
    font-size: clamp(1.875rem, 4.6vw, 3.25rem);
  }

  .lead {
    font-size: clamp(1rem, 1.6vw, 1.1875rem);
    max-width: 60ch;
    margin-top: 1.5rem;
  }

  /* Parcours */
  .dims {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .dim {
    border-radius: 16px;
    padding: 1.75rem;
  }

  .dim h3 {
    font-size: 1.25rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .dim p {
    font-size: 0.94rem;
    margin: 0;
  }

  .conviction {
    background: var(--ink);
    color: #dce4f0;
    border-radius: 16px;
    padding: clamp(1.6rem, 4vw, 2.5rem);
    margin-top: 1.5rem;
    font-size: clamp(1.0625rem, 2vw, 1.3125rem);
    line-height: 1.45;
  }

  .white {
    color: #fff;
  }

  @media (max-width: 860px) {
    .dims {
      grid-template-columns: 1fr;
    }
  }

  /* Méthode */
  .methode-section {
    background: #fff;
    border-block: 1px solid var(--border);
  }

  .methode-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .etape {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.4rem;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--border);
  }

  .etape:last-child {
    border-bottom: none;
  }

  .num {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .etape h3 {
    font-size: 1.25rem;
    margin-bottom: 0.2rem;
  }

  .etape p {
    font-size: 0.97rem;
    margin: 0;
  }

  /* Je suis / Je ne suis pas */
  .versus {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .v-head {
    padding: 1.25rem 1.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .oui-head {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .non-head {
    background: #fff;
    color: var(--muted);
  }

  .v-cell {
    padding: 1.25rem 1.5rem;
    font-size: 0.94rem;
  }

  .oui {
    background: #f7faff;
    color: var(--ink);
  }

  .non {
    background: #fff;
    color: var(--muted);
  }

  @media (max-width: 700px) {
    .versus {
      grid-template-columns: 1fr;
    }
    .v-head {
      display: none;
    }
    .oui::before,
    .non::before {
      display: block;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.3rem;
    }
    .oui::before {
      content: 'Je suis';
      color: var(--accent);
    }
    .non::before {
      content: 'Je ne suis pas';
      color: var(--muted);
    }
  }

  /* Vision */
  .vision {
    background: var(--ink);
    color: #fff;
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  .dark-eyebrow {
    display: inline-block;
    background: rgba(46, 142, 255, 0.18);
    color: #8fc0ff;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 13px;
    border-radius: 20px;
  }

  .vision h2 {
    font-size: clamp(1.5rem, 3.2vw, 2.25rem);
    color: #fff;
    margin: 1.1rem 0 1.5rem;
    max-width: 24ch;
  }

  .light-accent {
    color: #8fc0ff;
  }

  .vision-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: #b7c3d6;
    font-size: 1.0625rem;
  }

  /* CTA */
  .final-cta {
    padding-block: clamp(3.5rem, 8vw, 6.25rem);
    background: linear-gradient(180deg, var(--bg), var(--accent-soft));
    text-align: center;
  }

  .final-cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 1.75rem;
  }

  :global(.cta-big) {
    padding: 1.05rem 2rem !important;
    font-size: 1.0625rem !important;
  }
</style>
